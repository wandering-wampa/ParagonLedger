{
  "name": "paragon-ledger",
  "version": "0.1.0",
  "description": "Local City of Heroes Homecoming companion analytics dashboard",
  "main": "electron/main.cjs",
  "author": "ParagonLedger",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others --success first \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && set \"ELECTRON_RUN_AS_NODE=\" && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build:renderer": "vite build",
    "start": "set \"ELECTRON_RUN_AS_NODE=\" && electron .",
    "sync:badges": "node scripts/sync-badges-from-wiki.mjs"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "electron": "^36.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.4",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  }
}
